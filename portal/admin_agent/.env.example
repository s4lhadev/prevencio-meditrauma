# Copy to .env and fill. Run: uvicorn app:app --host 127.0.0.1 --port 9102
# (or use the systemd unit prevencion-admin-agent.service installed by deploy)

# ---- core ------------------------------------------------------------------
ADMIN_AGENT_SECRET=change_me_match_symfony_env
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=https://github.com/s4lhadev/prevencio-meditrauma
APP_PRODUCT=prevencion

# ---- agentic loop ----------------------------------------------------------
AGENT_MAX_TOOL_ROUNDS=12
AGENT_TOOL_CONTENT_MAX=600000
AGENT_HISTORY_BUDGET_CHARS=60000
AGENT_HISTORY_MIN_RECENT=10

# ---- sql tool (read-only role) --------------------------------------------
# Create the role once: see migrations/001_agent_init.sql
AGENT_DB_DSN=postgresql://agent_ro:CHANGE_ME@127.0.0.1:5432/prevencion
# Used ONLY by the deploy script to apply migrations (CREATE SCHEMA, GRANT, etc.).
# Must be a Postgres role with CREATE on the database. Do NOT reuse this for AGENT_DB_DSN.
AGENT_DB_ADMIN_DSN=postgresql://prevencion:prevencion123@127.0.0.1:5432/prevencion
AGENT_SQL_TIMEOUT_S=30
AGENT_MAX_SQL_ROWS=200
AGENT_SCHEMA_DIGEST_TTL_S=300
# Substring patterns; any table whose name contains one is denied at sql_execute.
AGENT_SQL_DENYLIST_PATTERNS=informe_medico,historia_clinica,paciente,vigilancia,aptitud,reconocimiento

# ---- shell tool (full access; kill switch) ---------------------------------
AGENT_SHELL_DISABLE=0
AGENT_SHELL_TIMEOUT_S=180
AGENT_SHELL_MAX_OUTPUT=1500000

# ---- log tool --------------------------------------------------------------
# Override individual paths if needed:
# AGENT_LOG_PATH_APACHE_ERROR=/var/log/apache2/error.log
# Or replace the whole map:
# AGENT_LOG_PATHS=apache_error=/var/log/apache2/error.log,symfony_prod_current=/path/...
AGENT_JOURNAL_UNITS=prevencion-admin-agent,apache2,postgresql

# ---- http_request tool -----------------------------------------------------
AGENT_HTTP_ALLOWED_HOSTS=127.0.0.1,localhost,app.mdtprevencion.com,portal.mdtprevencion.com
AGENT_HTTP_MAX_BODY=500000

# ---- web search ------------------------------------------------------------
# Empty or '*' = full public web. Comma list to restrict.
AGENT_WEB_INCLUDE_DOMAINS=
AGENT_WEB_FETCH_MAX_URLS=4
AGENT_WEB_FETCH_MAX_CHARS_PER_URL=50000

# ---- symfony_console (allowlist) ------------------------------------------
AGENT_SYMFONY_CONSOLE_ALLOWED=debug:router,debug:container,debug:config,debug:event-dispatcher,debug:translation,doctrine:schema:validate,doctrine:mapping:info,cache:pool:list,about
AGENT_SYMFONY_APP_PATHS=/home/administrador/prevencio/prevencio-meditrauma/current,/home/administrador/prevencio/prevencio-meditrauma/portal

# ---- repo paths ------------------------------------------------------------
# Defaults to two parents above admin_agent/ (i.e. repo root).
# AGENT_REPO_ROOT=/home/administrador/prevencio/prevencio-meditrauma
# AGENT_CODEBASE_ROOTS=/home/administrador/prevencio/prevencio-meditrauma/current,/home/administrador/prevencio/prevencio-meditrauma/portal
