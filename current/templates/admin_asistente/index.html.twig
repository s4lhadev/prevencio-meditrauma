<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Asistente — Prevención</title>
    <style>
        :root {
            --bg: #0f1419; --panel: #1a2332; --panel2: #11192b;
            --text: #e6edf3; --muted: #8b9cb3; --accent: #2bb673; --warn: #d97a2b; --err: #f85149; --tool: #7ea7ff;
            --border: #2a3a55;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
        .wrap { max-width: 880px; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
        h1 { font-size: 1.35rem; font-weight: 600; margin: 0 0 0.35rem; letter-spacing: -0.02em; }
        p.sub { color: var(--muted); font-size: 0.875rem; margin: 0 0 1.25rem; }
        a.back { color: var(--accent); text-decoration: none; font-size: 0.85rem; margin-right: 1rem; }
        a.back:hover { text-decoration: underline; }
        .topbar { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.75rem; }
        .badges { display: flex; gap: 0.4rem; align-items: center; }
        .badge { padding: 0.18rem 0.55rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em; border: 1px solid transparent; }
        .badge.tier-user { background: rgba(126,167,255,0.12); color: #a5c3ff; border-color: rgba(126,167,255,0.3); }
        .badge.tier-dev { background: rgba(217,122,43,0.12); color: #ffc28a; border-color: rgba(217,122,43,0.4); }
        .badge.btn { cursor: pointer; }
        .badge.btn:hover { filter: brightness(1.15); }
        .banner { background: rgba(248,81,73,0.12); border: 1px solid rgba(248,81,73,0.35); color: #ffb4b0; padding: 0.7rem 0.95rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.85rem; }
        .ix { background: var(--panel); border-radius: 10px; padding: 0.85rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; }
        .ix h2 { margin: 0 0 0.3rem; font-size: 0.95rem; }
        .ix p { margin: 0.2rem 0; color: var(--muted); }
        .ix code { color: #7ee2b8; }
        .ix .btns { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
        button { padding: 0.55rem 0.9rem; border: none; border-radius: 8px; background: var(--accent); color: #fff; font-weight: 600; cursor: pointer; font-size: 0.85rem; }
        button.secondary { background: #303d50; }
        button.danger { background: #5a1e1e; }
        button:disabled { opacity: 0.4; cursor: not-allowed; }

        .log { background: var(--panel); border-radius: 10px; padding: 1rem; min-height: 320px; max-height: 60vh; overflow-y: auto; margin-bottom: 1rem; font-size: 0.92rem; line-height: 1.5; }
        .turn { margin-bottom: 0.85rem; }
        .turn .role { font-weight: 600; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; opacity: 0.7; }
        .turn.user .role { color: #7ee2b8; }
        .turn.assistant .role { color: #a5d4ff; }
        .turn .body { white-space: pre-wrap; word-break: break-word; }
        .tool {
            background: var(--panel2); border: 1px solid var(--border); border-radius: 8px;
            padding: 0.5rem 0.75rem; margin: 0.4rem 0;
            font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.78rem;
        }
        .tool .head { display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }
        .tool .name { color: var(--tool); font-weight: 700; }
        .tool .status.ok { color: var(--accent); }
        .tool .status.err { color: var(--err); }
        .tool .args, .tool .res { margin-top: 0.4rem; padding: 0.4rem 0.5rem; background: #0a1020; border-radius: 5px; max-height: 240px; overflow: auto; white-space: pre-wrap; word-break: break-word; }
        .tool details summary { cursor: pointer; color: var(--muted); font-size: 0.74rem; }

        .row { display: flex; gap: 0.5rem; }
        textarea { flex: 1; min-height: 56px; max-height: 200px; resize: vertical; padding: 0.7rem 0.9rem; border-radius: 8px; border: 1px solid var(--border); background: #0d1117; color: var(--text); font-family: inherit; font-size: 0.95rem; }
        .meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.75rem; }
        .meta .session-id { font-family: ui-monospace, monospace; }
        .opgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem 1rem; margin-top: 0.5rem; }
        @media (max-width: 640px) { .opgrid { grid-template-columns: 1fr; } }
        .opgrid label { display: block; font-size: 0.72rem; color: var(--muted); margin-bottom: 0.2rem; }
        .opgrid input, .opgrid textarea { width: 100%; padding: 0.45rem 0.55rem; border-radius: 6px; border: 1px solid var(--border); background: #0d1117; color: var(--text); font: inherit; font-size: 0.85rem; }
        .opgrid textarea { min-height: 72px; resize: vertical; }
        .opspan2 { grid-column: 1 / -1; }
        #opstatus { font-size: 0.8rem; color: var(--muted); margin-top: 0.45rem; min-height: 1.2em; }
        .sess-panel .sess-toolbar { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-top: 0.5rem; }
        .sess-list { list-style: none; margin: 0.5rem 0 0; padding: 0; max-height: 180px; overflow-y: auto; border: 1px solid var(--border); border-radius: 8px; background: #0d1117; }
        .sess-list li { border-bottom: 1px solid var(--border); padding: 0.45rem 0.65rem; cursor: pointer; font-size: 0.82rem; display: flex; justify-content: space-between; gap: 0.5rem; align-items: baseline; }
        .sess-list li:last-child { border-bottom: none; }
        .sess-list li:hover { background: rgba(43,182,115,0.12); }
        .sess-list li.active { background: rgba(43,182,115,0.2); }
        .sess-list .t { color: var(--text); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .sess-list .d { color: var(--muted); font-size: 0.72rem; flex-shrink: 0; }
        #sessStatus { font-size: 0.78rem; color: var(--muted); margin-top: 0.35rem; min-height: 1.1em; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="topbar">
        <div>
            <a class="back" href="/admin/">← Volver al admin</a>
            <a class="back" href="{{ path('admin_asistente_logout') }}">Cerrar sesión del asistente</a>
        </div>
        <div class="badges">
            <span class="badge tier-dev">TOOLS</span>
        </div>
    </div>

    <h1>Asistente (Prevención)</h1>
    <p class="sub">Modo <strong>agente</strong> (estilo operador): el modelo puede usar herramientas en esta máquina — búsqueda en repo, SQL solo lectura vía <code>agent_ro</code>, shell con límites, HTTP a hosts permitidos, logs, Symfony console allowlist, web. Historial en servidor si hay BD del agente. Respuesta única al final (sin streaming).</p>

    {% if agent_unlock_notice is defined and agent_unlock_notice %}
        <div class="banner" style="background: rgba(43,182,115,0.12); border-color: rgba(43,182,115,0.45); color: #7ee2b8;">{{ agent_unlock_notice }}</div>
    {% endif %}
    {% for message in app.flashes('success') %}
        <div class="banner" style="background: rgba(43,182,115,0.12); border-color: rgba(43,182,115,0.45); color: #7ee2b8;">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="banner">{{ message }}</div>
    {% endfor %}

    {% if not assistant_configured %}
        <div class="banner">
            Configura <code>ADMIN_AGENT_INTERNAL_URL</code> y <code>ADMIN_AGENT_SECRET</code> en <code>.env</code> y arranca uvicorn.
        </div>
    {% endif %}

    <div class="ix" id="ixpanel">
        <h2>Índice del código (RAG)</h2>
        <p id="ixstat">Cargando estado…</p>
        <div class="btns">
            <button type="button" class="secondary" id="ixrefresh" {% if not assistant_configured %}disabled{% endif %}>Refrescar estado</button>
            <button type="button" id="ixincr" {% if not assistant_configured %}disabled{% endif %}>Reindexar incremental</button>
            <button type="button" class="danger" id="ixfull" {% if not assistant_configured %}disabled{% endif %}>Reindexar completo</button>
        </div>
    </div>

    <div class="ix" id="oppanel">
        <h2>Ajustes del agente (operador)</h2>
        <p>Con <code>AGENT_DB_DSN</code> configurado, los cambios se guardan en Postgres (<code>agent.operator_config</code>). Sin DSN solo verás valores por defecto y el guardado fallará hasta que haya base de datos del agente.</p>
        <div class="opgrid">
            <div>
                <label for="op_rounds">Máx. rondas de herramientas</label>
                <input type="number" id="op_rounds" min="1" max="64" step="1">
            </div>
            <div>
                <label for="op_temp">Temperatura</label>
                <input type="number" id="op_temp" min="0" max="2" step="0.05">
            </div>
            <div>
                <label for="op_hbud">Presupuesto historial (caract.)</label>
                <input type="number" id="op_hbud" min="1000" max="500000" step="500">
            </div>
            <div>
                <label for="op_hmin">Mín. mensajes recientes</label>
                <input type="number" id="op_hmin" min="1" max="500" step="1">
            </div>
            <div class="opspan2">
                <label for="op_model">Modelo OpenRouter (slug)</label>
                <input type="text" id="op_model" placeholder="p. ej. anthropic/claude-sonnet-4.6" autocomplete="off">
            </div>
            <div class="opspan2">
                <label for="op_append">Texto a añadir al system (instrucciones del operador)</label>
                <textarea id="op_append" placeholder="Reglas locales, tono, qué evitar…"></textarea>
            </div>
        </div>
        <div class="btns">
            <button type="button" id="opsave" {% if not assistant_configured %}disabled{% endif %}>Guardar ajustes</button>
            <button type="button" class="secondary" id="opreload" {% if not assistant_configured %}disabled{% endif %}>Recargar desde servidor</button>
        </div>
        <p id="opstatus"></p>
    </div>

    <div class="ix sess-panel" id="sessPanel">
        <h2>Conversaciones guardadas</h2>
        <p>Historial en Postgres si hay <code>AGENT_DB_DSN</code>. Elige una para ver mensajes y seguir chateando.</p>
        <div class="sess-toolbar">
            <button type="button" class="secondary" id="sessRefresh" {% if not assistant_configured %}disabled{% endif %}>Recargar lista</button>
            <button type="button" id="sessNew" {% if not assistant_configured %}disabled{% endif %}>Nueva conversación</button>
            <label style="font-size:0.8rem;color:var(--muted);display:inline-flex;align-items:center;gap:0.35rem;cursor:pointer;">
                <input type="checkbox" id="sessAllUsers" {% if not assistant_configured %}disabled{% endif %} />
                Ver todas (p. ej. sesiones antiguas «anon»)
            </label>
        </div>
        <ul class="sess-list" id="sessList" aria-label="Lista de conversaciones"></ul>
        <p id="sessStatus"></p>
    </div>

    <div class="log" id="log" aria-live="polite"></div>
    <div class="row">
        <textarea id="input" placeholder="Pregunta lo que quieras (Shift+Enter = nueva línea)…" rows="2"></textarea>
        <button type="button" id="send">Enviar</button>
    </div>
    <p class="meta">Sesión agente: <span class="session-id" id="sessionIdLabel">(se crea al enviar el primer mensaje)</span> · Puede tardar hasta varios minutos si hay muchas herramientas.</p>
</div>

<script>
(function () {
    var token = {{ agent_ajax_token|json_encode|raw }};
    var cfg = {{ assistant_configured|json_encode|raw }};
    var sessionWho = {{ agent_session_who|default('prevencion-agent-ui')|json_encode|raw }};

    var log = document.getElementById('log');
    var input = document.getElementById('input');
    var sendBtn = document.getElementById('send');
    var sessionId = null;
    var VIEW_MSG_MAX = 12000;

    function updateSessionLabel() {
        var el = document.getElementById('sessionIdLabel');
        if (!el) return;
        if (sessionId) {
            el.textContent = sessionId.slice(0, 8) + '…' + sessionId.slice(-4);
        } else {
            el.textContent = '(se crea al enviar el primer mensaje)';
        }
    }
    function clearChatLog() {
        while (log.firstChild) log.removeChild(log.firstChild);
    }
    function truncateForView(s) {
        s = s == null ? '' : String(s);
        if (s.length <= VIEW_MSG_MAX) return s;
        return s.slice(0, VIEW_MSG_MAX) + '\n… (truncado en vista)';
    }
    function renderHistoryMessages(rows) {
        clearChatLog();
        (rows || []).forEach(function (m) {
            var role = (m.role || '').toLowerCase();
            if (role === 'system') return;
            if (role === 'user') {
                appendUserTurn(truncateForView(m.content));
                return;
            }
            if (role === 'assistant') {
                var a = startAssistantTurn();
                var bodyText = truncateForView(m.content || '');
                if (m.tool_calls && m.tool_calls.length) {
                    bodyText += (bodyText ? '\n\n' : '') + '[tool_calls: ' + m.tool_calls.length + ']';
                }
                a.body.textContent = bodyText;
                return;
            }
            if (role === 'tool') {
                var label = 'Herramienta' + (m.name ? ' · ' + m.name : '');
                appendNote(label + '\n' + truncateForView(m.content));
            }
        });
        log.scrollTop = log.scrollHeight;
    }
    function formatSessionWhen(iso) {
        if (!iso) return '';
        var d = new Date(iso);
        if (isNaN(d.getTime())) return iso.slice(0, 16);
        return d.toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'short' });
    }
    function highlightActiveSession() {
        var ul = document.getElementById('sessList');
        if (!ul) return;
        [].forEach.call(ul.querySelectorAll('li'), function (li) {
            li.classList.toggle('active', sessionId && li.getAttribute('data-sid') === sessionId);
        });
    }
    function loadSessions() {
        if (!cfg) return;
        var st = document.getElementById('sessStatus');
        var ul = document.getElementById('sessList');
        var allCb = document.getElementById('sessAllUsers');
        var all = allCb && allCb.checked;
        st.textContent = 'Cargando…';
        var q = all ? 'limit=50&all=1' : 'limit=50&who=' + encodeURIComponent(sessionWho || '');
        fetch('{{ path('admin_asistente_sessions') }}?' + q, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) { return r.text().then(function (t) { return { r: r, t: t }; }); })
            .then(function (o) {
                var j = null;
                try { j = JSON.parse(o.t); } catch (e) {
                    st.textContent = 'Error al leer lista';
                    return;
                }
                if (!o.r.ok || j.error) {
                    st.textContent = 'Error: ' + JSON.stringify(j).slice(0, 200);
                    return;
                }
                if (!j.store_enabled) {
                    st.textContent = 'Sin almacén de sesiones (revisa AGENT_DB_DSN).';
                    ul.innerHTML = '';
                    return;
                }
                var rows = j.sessions || [];
                ul.innerHTML = '';
                rows.forEach(function (s) {
                    var li = document.createElement('li');
                    li.setAttribute('data-sid', s.id);
                    var title = (s.title && String(s.title).trim()) ? s.title : ('Chat ' + (s.id || '').slice(0, 8));
                    var sub = (s.who ? s.who + ' · ' : '') + formatSessionWhen(s.updated_at || s.created_at);
                    li.innerHTML = '<span class="t"></span><span class="d"></span>';
                    li.querySelector('.t').textContent = title;
                    li.querySelector('.d').textContent = formatSessionWhen(s.updated_at || s.created_at);
                    li.setAttribute('title', sub);
                    li.addEventListener('click', function () {
                        openSession(s.id);
                    });
                    ul.appendChild(li);
                });
                st.textContent = rows.length ? (rows.length + ' conversaciones') : 'Sin conversaciones guardadas.';
                highlightActiveSession();
            });
    }
    function openSession(sid) {
        if (!cfg || !sid) return;
        var st = document.getElementById('sessStatus');
        st.textContent = 'Cargando mensajes…';
        fetch('{{ path('admin_asistente_session_messages', { sessionId: '00000000-0000-4000-8000-000000000001' }) }}'.replace('00000000-0000-4000-8000-000000000001', sid) + '?limit=2000', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
            .then(function (r) { return r.text().then(function (t) { return { r: r, t: t }; }); })
            .then(function (o) {
                var j = null;
                try { j = JSON.parse(o.t); } catch (e) {
                    st.textContent = 'Error al leer historial';
                    return;
                }
                if (!o.r.ok || j.error) {
                    st.textContent = 'Error: ' + JSON.stringify(j).slice(0, 240);
                    return;
                }
                sessionId = sid;
                updateSessionLabel();
                renderHistoryMessages(j.messages || []);
                st.textContent = 'Historial cargado (' + (j.count || 0) + ' mensajes). Sigue escribiendo para continuar.';
                highlightActiveSession();
            });
    }
    document.getElementById('sessRefresh').addEventListener('click', loadSessions);
    document.getElementById('sessNew').addEventListener('click', function () {
        sessionId = null;
        updateSessionLabel();
        clearChatLog();
        highlightActiveSession();
        var st = document.getElementById('sessStatus');
        if (st) st.textContent = 'Nueva conversación: el próximo envío creará sesión.';
    });
    var sessAllEl = document.getElementById('sessAllUsers');
    if (sessAllEl) sessAllEl.addEventListener('change', loadSessions);
    if (cfg) loadSessions();

    // ---------- index status (unchanged) ----------
    function ixText(j) {
        if (!j || j.error) return 'Estado: ' + (j && (j.error || j.detail) ? JSON.stringify(j) : 'error');
        return 'Código raíz: <code>' + (j.codebase_root || '—') + '</code> · Ficheros: ' + (j.file_count || 0) + ' · Chunks: ' + (j.chunk_count || 0) + (j.last_reindex_utc ? ' · Última: ' + j.last_reindex_utc : '');
    }
    function loadIx() {
        if (!cfg) return;
        var el = document.getElementById('ixstat');
        fetch('{{ path('admin_asistente_index_status') }}', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) { return r.json(); })
            .then(function (j) { el.innerHTML = ixText(j); })
            .catch(function (e) { el.textContent = 'No se pudo leer el índice: ' + e; });
    }
    function doReindex(full) {
        if (!cfg) return;
        if (full && !window.confirm('¿Reindexar COMPLETO?')) return;
        var el = document.getElementById('ixstat');
        el.textContent = 'Indexando…';
        fetch('{{ path('admin_asistente_reindex') }}', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ _token: token, full: !!full })
        }).then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (o) {
            if (!o.ok) { el.textContent = 'Error: ' + JSON.stringify(o.j); return; }
            el.innerHTML = 'Listo. ' + (o.j.took_sec != null ? o.j.took_sec + ' s · ' : '') +
                'Reindexados: ' + (o.j.files_reindexed || 0) + ' · Sin cambio: ' + (o.j.files_unchanged || 0) +
                ' · Chunks: ' + (o.j.chunk_count || 0);
            loadIx();
        }).catch(function (e) { el.textContent = 'Error: ' + e; });
    }
    document.getElementById('ixrefresh').addEventListener('click', loadIx);
    document.getElementById('ixincr').addEventListener('click', function () { doReindex(false); });
    document.getElementById('ixfull').addEventListener('click', function () { doReindex(true); });
    loadIx();

    var opRounds = document.getElementById('op_rounds');
    var opTemp = document.getElementById('op_temp');
    var opModel = document.getElementById('op_model');
    var opAppend = document.getElementById('op_append');
    var opHbud = document.getElementById('op_hbud');
    var opHmin = document.getElementById('op_hmin');
    var opStatus = document.getElementById('opstatus');
    function fillOperatorForm(j) {
        if (!j || j.error) return;
        opRounds.value = j.max_tool_rounds != null ? j.max_tool_rounds : '';
        opTemp.value = j.temperature != null ? j.temperature : '';
        opModel.value = j.openrouter_model != null ? j.openrouter_model : '';
        opAppend.value = j.system_append != null ? j.system_append : '';
        if (opHbud) opHbud.value = j.history_budget_chars != null ? j.history_budget_chars : '';
        if (opHmin) opHmin.value = j.history_min_recent != null ? j.history_min_recent : '';
        var env = j.env_model_default || '—';
        var cap = j.env_max_tool_rounds_cap != null ? j.env_max_tool_rounds_cap : '—';
        var st = j.store || '—';
        opStatus.textContent = 'Almacén: ' + st + ' · modelo env ' + env + ' · tope rondas ' + cap;
    }
    function loadOperatorConfig() {
        if (!cfg) return;
        opStatus.textContent = 'Cargando…';
        fetch('{{ path('admin_asistente_operator_config_get') }}', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) { return r.json(); })
            .then(function (j) {
                if (j.error) { opStatus.textContent = 'Error: ' + JSON.stringify(j); return; }
                fillOperatorForm(j);
            })
            .catch(function (e) { opStatus.textContent = 'Error: ' + e; });
    }
    function saveOperatorConfig() {
        if (!cfg) return;
        opStatus.textContent = 'Guardando…';
        var rounds = parseInt(String(opRounds.value), 10);
        var temp = parseFloat(String(opTemp.value));
        var hb = opHbud ? parseInt(String(opHbud.value), 10) : NaN;
        var hm = opHmin ? parseInt(String(opHmin.value), 10) : NaN;
        fetch('{{ path('admin_asistente_operator_config_save') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                _token: token,
                max_tool_rounds: isNaN(rounds) ? undefined : rounds,
                temperature: isNaN(temp) ? undefined : temp,
                openrouter_model: opModel.value,
                system_append: opAppend.value,
                history_budget_chars: isNaN(hb) ? undefined : hb,
                history_min_recent: isNaN(hm) ? undefined : hm
            })
        }).then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (o) {
            if (!o.ok || o.j.error) {
                opStatus.textContent = 'Error: ' + JSON.stringify(o.j || o);
                return;
            }
            fillOperatorForm(o.j);
            opStatus.textContent = 'Guardado.';
        }).catch(function (e) { opStatus.textContent = 'Error: ' + e; });
    }
    document.getElementById('opsave').addEventListener('click', saveOperatorConfig);
    document.getElementById('opreload').addEventListener('click', loadOperatorConfig);
    loadOperatorConfig();

    // ---------- chat rendering ----------
    function el(tag, cls, text) {
        var n = document.createElement(tag);
        if (cls) n.className = cls;
        if (text != null) n.textContent = text;
        return n;
    }
    function appendUserTurn(text) {
        var t = el('div', 'turn user');
        t.appendChild(el('div', 'role', 'Tú'));
        t.appendChild(el('div', 'body', text));
        log.appendChild(t);
        log.scrollTop = log.scrollHeight;
    }
    function startAssistantTurn() {
        var t = el('div', 'turn assistant');
        t.appendChild(el('div', 'role', 'Asistente'));
        var body = el('div', 'body', '');
        t.appendChild(body);
        log.appendChild(t);
        log.scrollTop = log.scrollHeight;
        return { turn: t, body: body };
    }
    function appendNote(text) {
        var n = el('div', 'meta', text);
        n.style.margin = '0.4rem 0';
        log.appendChild(n);
        log.scrollTop = log.scrollHeight;
    }

    function parseChatResponseBody(text) {
        text = text == null ? '' : text;
        var t = text.trim();
        if (!t) {
            return { j: null, parseError: 'empty' };
        }
        try {
            return { j: JSON.parse(text), parseError: null };
        } catch (e) {
            return { j: null, parseError: e };
        }
    }

    function sendJsonChat(text) {
        if (!cfg) return;
        var assistant = startAssistantTurn();
        assistant.body.textContent = '…';
        sendBtn.disabled = true;
        var payload = {
            _token: token,
            message: text,
            agentic: true,
            session_id: sessionId,
            create_session: !sessionId
        };
        fetch('{{ path('admin_asistente_chat') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(payload)
        }).then(function (r) {
            return r.text().then(function (text) {
                var p = parseChatResponseBody(text);
                return { ok: r.ok, r: r, text: text, j: p.j, parseError: p.parseError };
            });
        }).then(function (o) {
            if (o.parseError) {
                assistant.body.textContent = '';
                var snippet = (o.text || '').replace(/\s+/g, ' ').slice(0, 280);
                appendNote('Error: respuesta no JSON (HTTP ' + o.r.status + '). Suele ser HTML de error del servidor o timeout. Fragmento: ' + snippet);
                return;
            }
            if (o.ok && o.j && typeof o.j.reply === 'string') {
                assistant.body.textContent = o.j.reply;
                if (o.j.session_id) {
                    sessionId = o.j.session_id;
                    updateSessionLabel();
                    highlightActiveSession();
                    loadSessions();
                }
                if (o.j.tool_trace && o.j.tool_trace.length) {
                    var done = o.j.tool_trace.filter(function (x) { return x.type === 'result'; });
                    if (done.length) {
                        appendNote('Herramientas: ' + done.map(function (x) {
                            return x.name + (x.ok ? ' ✓' : ' ✗');
                        }).join(', '));
                    }
                }
                log.scrollTop = log.scrollHeight;
                return;
            }
            assistant.body.textContent = '';
            appendNote('Error: ' + JSON.stringify(o.j || {}).slice(0, 400));
        }).catch(function (e) {
            assistant.body.textContent = '';
            appendNote('Error: ' + (e && e.message ? e.message : e));
        }).then(function () {
            sendBtn.disabled = false;
            input.focus();
        });
    }
    function run() {
        var text = (input.value || '').trim();
        if (!text) return;
        appendUserTurn(text);
        input.value = '';
        sendJsonChat(text);
    }
    sendBtn.addEventListener('click', run);
    input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); run(); }
    });
})();
</script>
{% if agent_replace_history is defined and agent_replace_history %}
<script>
(function () {
    var u = {{ path('admin_asistente')|json_encode|raw }};
    try { history.replaceState(null, '', u); } catch (e) {}
})();
</script>
{% endif %}
